    <xyztiles zmin="0" name="【Proxy】Google History (Hybrid)" referer="https://www.google.com/maps" zmax="19" url="https://auto-map.YOUR_DOMAIN/google-history?text=1&amp;x={x}&amp;y={y}&amp;z={z}&amp;token=YOUR_TOKEN" password="" http-header:referer="https://www.google.com/maps" username="" tilePixelRatio="0" authcfg=""/>

