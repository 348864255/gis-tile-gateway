<!DOCTYPE connections>
<qgsXYZTilesConnections xmlns:http-header="https://qgis.org/http-header" version="1.0">

    <!-- ================================================================== -->
    <!-- Proxy (via Cloudflare Worker)                                       -->
    <!-- Replace YOUR_DOMAIN and YOUR_TOKEN before use                       -->
    <!-- ================================================================== -->

    <!-- ========== Auto-satellite (smart fallback) ========== -->
    <xyztiles zmin="0" name="【Proxy】Auto Satellite" referer="" zmax="19" url="https://auto-map.YOUR_DOMAIN/auto-satellite?x={x}&amp;y={y}&amp;z={z}&amp;token=YOUR_TOKEN" password="" http-header:referer="" username="" tilePixelRatio="0" authcfg=""/>

    <!-- ========== Google Satellite ========== -->
    <xyztiles zmin="0" name="【Proxy】Google Satellite" referer="https://www.google.com/maps" zmax="19" url="https://auto-map.YOUR_DOMAIN/google?lyrs=s&amp;x={x}&amp;y={y}&amp;z={z}&amp;scale=1&amp;token=YOUR_TOKEN" password="" http-header:referer="https://www.google.com/maps" username="" tilePixelRatio="0" authcfg=""/>
    <xyztiles zmin="0" name="【Proxy】Google Hybrid" referer="https://www.google.com/maps" zmax="19" url="https://auto-map.YOUR_DOMAIN/google?lyrs=y&amp;x={x}&amp;y={y}&amp;z={z}&amp;scale=1&amp;token=YOUR_TOKEN" password="" http-header:referer="https://www.google.com/maps" username="" tilePixelRatio="0" authcfg=""/>

